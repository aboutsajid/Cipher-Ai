@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Geist:wght@300;400;500;600&family=Rajdhani:wght@600;700&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg-0: #0f1115;
  --bg-1: #151821;
  --bg-2: #1a1f2a;
  --bg-3: #202736;
  --bg-4: #273142;
  --bg-elev: rgba(255,255,255,0.045);
  --border: rgba(255,255,255,0.07);
  --border-hover: rgba(255,255,255,0.12);
  --text-1: #edf1f8;
  --text-2: #a1adbf;
  --text-3: #657186;
  --accent: #00f5c4;
  --accent-dim: rgba(0,245,196,0.14);
  --accent-hover: #64ffe0;
  --green: #10b981;
  --green-dim: rgba(16,185,129,0.15);
  --red: #ef4444;
  --red-dim: rgba(239,68,68,0.12);
  --radius: 10px;
  --radius-sm: 6px;
  --radius-lg: 18px;
  --font: 'Geist', -apple-system, sans-serif;
  --mono: 'JetBrains Mono', 'Fira Code', monospace;
  --sidebar-w: 272px;
  --panel-w: 356px;
}

body[data-theme="light"] {
  --bg-0: #f3f6fb;
  --bg-1: #ffffff;
  --bg-2: #f1f5fb;
  --bg-3: #e7edf6;
  --bg-4: #d8e2ef;
  --bg-elev: rgba(15, 23, 42, 0.035);
  --border: rgba(15, 23, 42, 0.12);
  --border-hover: rgba(15, 23, 42, 0.22);
  --text-1: #0f172a;
  --text-2: #334155;
  --text-3: #64748b;
  --accent: #2563eb;
  --accent-dim: rgba(37, 99, 235, 0.14);
  --accent-hover: #1d4ed8;
  --green: #059669;
  --green-dim: rgba(5, 150, 105, 0.14);
  --red: #dc2626;
  --red-dim: rgba(220, 38, 38, 0.12);
}

html, body { height: 100%; overflow: hidden; background: var(--bg-0); color: var(--text-1); font-family: var(--font); font-size: 14px; line-height: 1.6; }

body, .sidebar, .chat-area, .chat-header, .composer, .right-panel, .field-input, .composer-inner, .router-log, .modal {
  transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
}

.app {
  display: flex;
  height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at top left, rgba(0,245,196,0.08), transparent 22%),
    radial-gradient(circle at top right, rgba(47,143,255,0.1), transparent 24%),
    var(--bg-0);
}

:focus-visible {
  outline: 2px solid rgba(0,245,196,0.78);
  outline-offset: 2px;
}

body[data-theme="light"] :focus-visible {
  outline-color: rgba(37, 99, 235, 0.55);
}

/* â”€â”€ Sidebar â”€â”€ */
.sidebar {
  width: var(--sidebar-w);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.02), transparent 20%),
    var(--bg-1);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  box-shadow: inset -1px 0 0 rgba(255,255,255,0.02);
}

.sidebar-header {
  padding: 18px 16px 16px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
}

.brand { display: flex; align-items: center; gap: 12px; }

.brand-icon {
  width: 56px; height: 56px;
  background: rgba(255,255,255,0.02);
  border: 1px solid var(--border);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.brand-icon-image {
  width: 46px;
  height: 46px;
  display: block;
  object-fit: contain;
}
.brand-text { display: flex; flex-direction: column; gap: 3px; }
.brand-sub { display: block; font-size: 10px; color: var(--text-3); letter-spacing: 0.04em; }
.brand-motto { display: block; font-size: 11.5px; color: var(--text-2); font-weight: 500; letter-spacing: 0.02em; max-width: 230px; line-height: 1.35; }

.cipher-logo {
  display: inline-flex;
  align-items: flex-start;
  line-height: 1;
  font-size: 30px;
}
.cipher-logo .word {
  font-family: 'Rajdhani', sans-serif;
  font-weight: 800;
  letter-spacing: 0.12em;
  color: #00f5c4;
  position: relative;
}
.cipher-logo .word::after {
  content: '';
  position: absolute;
  bottom: -3px;
  left: 0;
  width: 100%;
  height: 1px;
  background: linear-gradient(90deg, #00f5c4, transparent);
}
.cipher-logo .tm {
  font-family: 'Rajdhani', sans-serif;
  font-weight: 600;
  color: rgba(0, 245, 196, 0.8);
  margin-left: -1px;
  margin-top: 5px;
  line-height: 1;
  font-size: 14px;
}
.cipher-logo .tool {
  font-family: 'Rajdhani', sans-serif;
  font-weight: 800;
  background: linear-gradient(135deg, #5debe1 0%, #4e7dff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  margin-left: 6px;
  letter-spacing: 0.02em;
}

body[data-theme="light"] .brand-icon {
  background: #ffffff;
  border-color: rgba(15, 23, 42, 0.1);
}
body[data-theme="light"] .chat-header {
  background: rgba(255,255,255,0.82);
  box-shadow: 0 1px 0 rgba(15,23,42,0.08);
}
body[data-theme="light"] .btn-topbar-action {
  color: var(--text-2);
  border-color: var(--border);
  background: transparent;
}
body[data-theme="light"] .btn-topbar-action.active {
  color: var(--text-2);
  border-color: var(--border);
  background: transparent;
}
body[data-theme="light"] .cipher-logo .word { color: #089981; }
body[data-theme="light"] .cipher-logo .word::after { background: linear-gradient(90deg, #089981, transparent); }
body[data-theme="light"] .cipher-logo .tm { color: rgba(8, 153, 129, 0.8); }
body[data-theme="light"] .cipher-logo .tool {
  background: linear-gradient(135deg, #06b6d4 0%, #2563eb 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
body[data-theme="light"] .sidebar-credit-word { color: #089981; }
body[data-theme="light"] .sidebar-credit-tm { color: rgba(8, 153, 129, 0.8); }
body[data-theme="light"] .sidebar-credit-tool {
  background: linear-gradient(135deg, #06b6d4 0%, #2563eb 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
body[data-theme="light"] .empty-motto { color: #0ea5a4; }

.btn-new {
  width: 32px; height: 32px;
  border: 1px solid var(--border);
  border-radius: 10px;
  background: rgba(255,255,255,0.03);
  color: var(--text-2);
  font-size: 18px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s ease;
}
.btn-new:hover { background: var(--bg-3); color: var(--text-1); border-color: var(--border-hover); transform: translateY(-1px); }
.btn-new-inline { flex: 0 0 auto; }
.chat-list-search {
  padding: 10px 12px 2px;
}

.chat-list-search-inner {
  position: relative;
  display: flex;
  align-items: center;
  gap: 8px;
}
.chat-search-import-btn,
.btn-plain {
  height: 34px;
  padding: 0 10px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--text-2);
  font-size: 11px;
  font-weight: 400;
  font-family: var(--font);
  cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: none;
}
.chat-search-import-btn:hover,
.btn-plain:hover {
  background: var(--bg-3);
  color: var(--text-1);
  border-color: var(--border-hover);
  box-shadow: none;
}
.chat-search-import-btn:focus-visible,
.btn-plain:focus-visible {
  outline: 1px solid var(--border-hover);
  outline-offset: 0;
  background: var(--bg-3);
  color: var(--text-1);
  border-color: var(--border-hover);
}
.chat-header-right .btn-plain,
.chat-title-actions .btn-plain,
.chat-header-right .chat-search-import-btn,
.chat-title-actions .chat-search-import-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  flex-shrink: 0;
}
.btn-plain:active,
.chat-search-import-btn:active {
  transform: none;
}
.chat-header-right .btn-plain.active,
.chat-title-actions .btn-plain.active,
.chat-header-right .chat-search-import-btn.active,
.chat-title-actions .chat-search-import-btn.active {
  background: transparent;
  color: var(--text-2);
  border-color: var(--border);
  box-shadow: none;
}
body[data-theme="light"] .btn-plain,
body[data-theme="light"] .chat-search-import-btn {
  color: var(--text-2);
  border-color: var(--border);
  background: transparent;
}
body[data-theme="light"] .btn-provider-switch:hover,
body[data-theme="light"] .composer-tool-btn:hover,
body[data-theme="light"] .mode-btn:hover,
body[data-theme="light"] .btn-provider-switch.active,
body[data-theme="light"] .mode-btn.active,
body[data-theme="light"] .mode-btn-save.active,
body[data-theme="light"] .btn-provider-switch:focus-visible,
body[data-theme="light"] .composer-tool-btn:focus-visible,
body[data-theme="light"] .mode-btn:focus-visible {
  background: var(--bg-3);
  color: var(--text-1);
  box-shadow: none;
}
body[data-theme="light"] .btn-plain:hover,
body[data-theme="light"] .chat-search-import-btn:hover,
body[data-theme="light"] .btn-plain:focus-visible,
body[data-theme="light"] .chat-search-import-btn:focus-visible {
  background: var(--bg-3);
  color: var(--text-1);
  border-color: var(--border-hover);
}
body[data-theme="light"] .chat-header-right .btn-plain.active,
body[data-theme="light"] .chat-title-actions .btn-plain.active,
body[data-theme="light"] .chat-header-right .chat-search-import-btn.active,
body[data-theme="light"] .chat-title-actions .chat-search-import-btn.active {
  background: transparent;
  color: var(--text-2);
  border-color: var(--border);
}

.chat-list-search-icon {
  position: absolute;
  left: 10px;
  color: var(--text-3);
  font-size: 12px;
  pointer-events: none;
}

.chat-search-input {
  width: 100%;
  height: 34px;
  border: 1px solid var(--border);
  border-radius: 10px;
  background: rgba(255,255,255,0.02);
  color: var(--text-2);
  font-family: var(--font);
  font-size: 12px;
  padding: 0 26px 0 28px;
  outline: none;
}

.chat-search-input:focus {
  border-color: rgba(0,245,196,0.4);
  box-shadow: 0 0 0 2px rgba(0,245,196,0.12);
  color: var(--text-1);
}

.chat-search-clear-btn {
  position: absolute;
  right: 5px;
  width: 20px;
  height: 20px;
  border: none;
  border-radius: 50%;
  background: transparent;
  color: var(--text-3);
  font-size: 16px;
  line-height: 1;
  cursor: pointer;
  display: none;
  align-items: center;
  justify-content: center;
}

.chat-search-clear-btn.visible {
  display: inline-flex;
}

.chat-search-clear-btn:hover {
  background: var(--bg-3);
  color: var(--text-1);
}

.chat-list { flex: 1; overflow-y: auto; padding: 12px 12px; display: flex; flex-direction: column; gap: 8px; }
.chat-list::-webkit-scrollbar { width: 4px; }
.chat-list::-webkit-scrollbar-thumb { background: var(--bg-4); border-radius: 2px; }

.chat-item {
  padding: 12px 12px;
  border-radius: 12px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  border: 1px solid rgba(255,255,255,0.04);
  background: rgba(255,255,255,0.015);
}
.chat-item:hover { background: var(--bg-elev); border-color: var(--border-hover); transform: translateX(2px); }
.chat-item.active { background: linear-gradient(135deg, rgba(0,245,196,0.11), rgba(47,143,255,0.09)); border-color: rgba(0,245,196,0.28); box-shadow: 0 0 0 1px rgba(0,245,196,0.08) inset, 0 10px 18px rgba(0,0,0,0.12); }

.chat-item-title { font-size: 12.5px; color: var(--text-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; }
.chat-item.active .chat-item-title { color: var(--text-1); }
.chat-list-empty {
  font-size: 12px;
  color: var(--text-3);
  padding: 14px 10px;
  line-height: 1.5;
}

.sidebar-credit {
  border-top: 1px solid var(--border);
  padding: 10px 14px 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  color: var(--text-3);
  line-height: 1.35;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.chat-item-del {
  width: 20px; height: 20px;
  background: none; border: none;
  color: var(--text-3);
  cursor: pointer; border-radius: 4px;
  display: none; align-items: center; justify-content: center;
  padding: 0;
  flex-shrink: 0;
}
.chat-item-del svg {
  width: 12px;
  height: 12px;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.7;
  stroke-linecap: round;
  stroke-linejoin: round;
}
.chat-item:hover .chat-item-del { display: flex; }
.chat-item-del:hover { background: var(--red-dim); color: var(--red); }

.provider-switcher,
.composer-mode-switcher,
.composer-tools-row {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px;
  margin: 0 0 10px 4px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(255,255,255,0.04);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
  align-self: flex-start;
}

.btn-provider-switch,
.composer-tool-btn {
  height: auto;
  min-height: 0;
  padding: 5px 10px;
  background: transparent;
  border: none;
  border-radius: 999px;
  color: var(--text-2);
  font-size: 11px;
  font-weight: 600;
  line-height: 1.2;
  cursor: pointer;
  font-family: var(--font);
  transition: color 0.15s ease, background-color 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
}
.btn-provider-switch:hover,
.composer-tool-btn:hover {
  background: rgba(255,255,255,0.04);
  color: var(--text-1);
}
.btn-provider-switch:focus-visible,
.composer-tool-btn:focus-visible,
.mode-btn:focus-visible {
  outline: 1px solid var(--border-hover);
  outline-offset: 0;
  background: rgba(255,255,255,0.04);
  color: var(--text-1);
}
.btn-provider-switch.active {
  background: rgba(255,255,255,0.04);
  color: var(--text-1);
  box-shadow: none;
}
.composer-tool-btn {
  min-width: 78px;
  justify-content: center;
  display: inline-flex;
  align-items: center;
}

#quick-claude-btn.status-ok {
  border-color: rgba(0,245,196,0.42);
  color: var(--accent);
}

#quick-claude-btn.status-busy {
  border-color: rgba(47,143,255,0.4);
  color: #9bd5ff;
}

#quick-claude-btn.status-err {
  border-color: rgba(255,96,96,0.42);
  color: #ff9d9d;
}

/* â”€â”€ Chat Area â”€â”€ */
.chat-area { flex: 1; display: flex; flex-direction: column; min-width: 0; background: transparent; animation: chatAreaIn 0.25s ease; }

.chat-header {
  min-height: 78px;
  padding: 16px 24px 15px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-shrink: 0;
  background: rgba(21, 24, 33, 0.72);
  backdrop-filter: blur(12px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
}

.chat-header-left { display: flex; flex-direction: column; align-items: flex-start; gap: 8px; min-width: 0; flex: 0 1 auto; }
.topbar-brand { display: inline-flex; align-items: center; gap: 8px; padding-right: 4px; }
.topbar-brand-icon { width: 24px; height: 24px; border-radius: 6px; box-shadow: 0 0 14px rgba(0,245,196,0.2); }
.topbar-brand-text {
  font-family: 'Rajdhani', sans-serif;
  font-size: 20px;
  font-weight: 700;
  letter-spacing: 0.07em;
  color: var(--accent);
  text-shadow: 0 0 12px rgba(0,245,196,0.2);
}
.chat-title-stack { display: flex; flex-direction: column; min-width: 0; }
.chat-title-label { font-size: 10px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.08em; line-height: 1; }
.chat-title-display { font-size: 15px; font-weight: 700; color: var(--text-1); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 280px; line-height: 1.2; }
.chat-title-actions { display: inline-flex; align-items: center; gap: 6px; }

.chat-header-right {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1 1 auto;
  min-width: 0;
  flex-wrap: nowrap;
  justify-content: flex-start;
  overflow-x: auto;
  overflow-y: hidden;
  white-space: nowrap;
  padding-bottom: 2px;
}
.chat-header-right > * { flex-shrink: 0; }
.chat-header-right > :first-child { margin-left: auto; }
.chat-header-right::-webkit-scrollbar { height: 4px; }
.chat-header-right::-webkit-scrollbar-thumb { background: var(--bg-4); border-radius: 999px; }

@media (max-width: 1380px) {
  .chat-header {
    align-items: flex-start;
    flex-direction: column;
  }
  .chat-header-left,
  .chat-header-right {
    width: 100%;
  }
  .chat-header-right {
    justify-content: flex-start;
  }
  .chat-header-right > :first-child {
    margin-left: 0;
  }
}

.btn-topbar-action {
  height: 34px;
  padding: 0 10px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--text-2);
  font-size: 11px;
  font-weight: 400;
  font-family: var(--font);
  cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: none;
}
.btn-topbar-action:hover {
  transform: none;
  filter: none;
  background: var(--bg-3);
  border-color: var(--border-hover);
  color: var(--text-1);
  box-shadow: none;
}
.btn-topbar-action:active { transform: none; }
.btn-topbar-action.active {
  background: transparent;
  color: var(--text-2);
  border-color: var(--border);
  box-shadow: none;
}

.mode-switcher {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(255,255,255,0.04);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
}
.mode-btn {
  border: none;
  background: transparent;
  color: var(--text-2);
  font-size: 11px;
  font-weight: 600;
  font-family: var(--font);
  border-radius: 999px;
  padding: 5px 10px;
  cursor: pointer;
  transition: color 0.15s ease, background-color 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
}
.mode-btn:hover {
  color: var(--text-1);
  background: rgba(255,255,255,0.04);
}
.mode-btn.active {
  background: rgba(255,255,255,0.04);
  color: var(--text-1);
  box-shadow: none;
}
.mode-btn-save {
  color: var(--text-2);
}
.mode-btn-save.active {
  background: rgba(255,255,255,0.04);
  color: var(--text-1);
  box-shadow: none;
}
.composer-mode-switcher {
  align-self: flex-start;
}

.system-prompt-panel {
  padding: 10px 20px 12px;
  border-bottom: 1px solid var(--border);
  background: rgba(21, 24, 33, 0.6);
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.system-prompt-panel textarea.field-input {
  min-height: 70px;
  max-height: 170px;
}
.system-prompt-actions {
  display: flex;
  justify-content: flex-end;
}

.btn-theme {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: 34px;
  padding: 0 10px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--text-2);
  font-size: 11px;
  font-weight: 400;
  font-family: var(--font);
  cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: none;
}
.btn-theme:hover {
  background: var(--bg-3);
  color: var(--text-1);
  border-color: var(--border-hover);
  box-shadow: none;
}
#theme-toggle-icon {
  width: 14px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  line-height: 1;
}

.model-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 0 12px;
  height: 32px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(255,255,255,0.03);
  transition: all 0.2s ease;
}
.model-pill:hover { border-color: var(--border-hover); background: rgba(255,255,255,0.06); }
.model-pill-icon { color: var(--accent); font-size: 11px; text-shadow: 0 0 10px rgba(0,245,196,0.25); }
.model-select {
  background: transparent;
  border: none;
  color: var(--text-1);
  font-size: 12px;
  font-weight: 600;
  font-family: var(--font);
  cursor: pointer;
  outline: none;
  max-width: 190px;
  min-width: 130px;
  appearance: none;
}

/* â”€â”€ Messages â”€â”€ */
.messages {
  flex: 1;
  overflow-y: auto;
  padding: 30px 0 18px;
  display: flex;
  flex-direction: column;
  gap: 0;
  will-change: transform;
  transform: translateZ(0);
}
.messages::-webkit-scrollbar { width: 4px; }
.messages::-webkit-scrollbar-thumb { background: var(--bg-4); border-radius: 2px; }

.empty-state { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--text-3); gap: 10px; text-align: center; padding: 0 20px; }
.empty-icon { font-size: 48px; opacity: 0.95; filter: drop-shadow(0 0 10px rgba(0,245,196,0.18)); }
.empty-state p { font-size: 22px; font-weight: 700; color: var(--text-1); letter-spacing: -0.01em; }
.empty-state span { font-size: 13px; color: var(--text-2); }
.empty-subtle-icon { color: var(--accent); margin-right: 5px; }
.empty-motto { font-size: 11px; color: #5debe1; margin-top: 6px; letter-spacing: 0.03em; text-align: center; }

.msg-wrapper {
  padding: 14px 28px;
  display: flex;
  gap: 14px;
  animation: fadeIn 0.2s ease;
}
.msg-wrapper:hover { background: rgba(255,255,255,0.026); }
body[data-theme="light"] .msg-wrapper:hover { background: rgba(15, 23, 42, 0.04); }

@keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }
@keyframes chatAreaIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

.msg-avatar {
  width: 28px; height: 28px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 600;
  flex-shrink: 0;
  margin-top: 2px;
}
.msg-avatar.user { background: var(--accent-dim); color: var(--accent-hover); border: 1px solid rgba(0,245,196,0.24); }
.msg-avatar.assistant { background: var(--bg-3); color: var(--text-2); border: 1px solid var(--border); }

.msg-body { flex: 1; min-width: 0; position: relative; }
.msg-role { font-size: 11px; font-weight: 600; color: var(--text-3); margin-bottom: 6px; letter-spacing: 0.06em; text-transform: uppercase; }
.msg-content { font-size: 14px; color: var(--text-1); line-height: 1.82; word-break: break-word; max-width: 82ch; }
.msg-content.error { color: var(--red); font-style: italic; }
.msg-content p { margin-bottom: 10px; }
.msg-content p:last-child { margin-bottom: 0; }
.msg-content pre { background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 14px; overflow-x: auto; margin: 10px 0; }
.msg-content code { font-family: var(--mono); font-size: 13px; }
.msg-content :not(pre) > code { background: var(--bg-3); padding: 2px 6px; border-radius: 4px; font-size: 12.5px; }
.msg-content strong { font-weight: 600; color: var(--text-1); }
.msg-content ul, .msg-content ol { padding-left: 20px; margin: 8px 0; }
.msg-content li { margin: 3px 0; }
.msg-content h1, .msg-content h2, .msg-content h3 { font-weight: 600; margin: 14px 0 6px; color: var(--text-1); }

.code-block { position: relative; margin: 10px 0; }
.code-block pre { margin: 0; padding-top: 28px; }
.copy-btn {
  position: absolute;
  top: 6px;
  right: 6px;
  border: 1px solid var(--border);
  background: var(--bg-3);
  color: var(--text-2);
  border-radius: 4px;
  font-size: 11px;
  padding: 2px 8px;
  cursor: pointer;
  font-family: var(--font);
}
.copy-btn:hover { border-color: var(--border-hover); color: var(--text-1); }
.code-actions {
  position: absolute;
  top: 6px;
  right: 6px;
  display: inline-flex;
  gap: 6px;
}
.code-actions .copy-btn,
.run-btn {
  position: static;
  border: 1px solid var(--border);
  background: var(--bg-3);
  color: var(--text-2);
  border-radius: 4px;
  font-size: 11px;
  padding: 2px 8px;
  cursor: pointer;
  font-family: var(--font);
}
.code-actions .copy-btn:hover,
.run-btn:hover { border-color: var(--border-hover); color: var(--text-1); }
.code-block pre { padding-top: 36px; }
.code-output {
  margin-top: 8px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--bg-2);
  padding: 8px 10px;
  font-size: 12px;
  color: var(--text-2);
  white-space: pre-wrap;
  font-family: var(--mono);
}
.code-output.error {
  color: var(--red);
  border-color: rgba(239,68,68,0.35);
}

.msg-model {
  display: inline-flex;
  align-items: center;
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 1px 8px;
  margin-top: 8px;
  font-size: 11px;
  color: var(--text-2);
  background: var(--bg-2);
  font-family: var(--mono);
}
.msg-token {
  font-size: 10px;
  color: var(--text-3);
  margin-top: 4px;
  font-family: var(--mono);
}
.msg-hover-actions {
  position: absolute;
  top: 0;
  right: 0;
  display: inline-flex;
  gap: 6px;
  opacity: 0;
  pointer-events: none;
  transform: translateY(-2px);
  transition: opacity 0.18s ease, transform 0.18s ease;
}
.msg-wrapper:hover .msg-hover-actions,
.msg-wrapper:focus-within .msg-hover-actions {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}
.msg-action-btn {
  height: 24px;
  padding: 0 8px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: var(--bg-3);
  color: var(--text-2);
  font-size: 11px;
  font-family: var(--font);
  cursor: pointer;
}
.msg-action-btn:hover {
  border-color: var(--border-hover);
  color: var(--text-1);
}

.cursor-blink { display: inline-block; width: 2px; height: 14px; background: var(--accent); border-radius: 1px; margin-left: 2px; animation: blink 1s step-end infinite; vertical-align: middle; }
@keyframes blink { 50% { opacity: 0; } }

/* â”€â”€ Composer â”€â”€ */
.composer {
  padding: 14px 22px 14px;
  border-top: 1px solid var(--border);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.02), transparent 40%),
    var(--bg-1);
  flex-shrink: 0;
}

.composer-inner {
  display: flex;
  gap: 6px;
  align-items: center;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 3px 5px 3px 12px;
  min-height: 36px;
  box-shadow: none;
  transition: border-color 0.15s ease, background-color 0.15s ease;
}
.composer-inner:focus-within { border-color: var(--border-hover); box-shadow: none; }

#composer-input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  color: var(--text-1);
  font-size: 14px;
  font-family: var(--font);
  resize: none;
  max-height: 160px;
  min-height: 16px;
  line-height: 1.25;
  padding: 2px 0 0;
}
#composer-input::placeholder { color: var(--text-3); }

.btn-send {
  width: 26px; height: 26px;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 999px;
  color: var(--accent);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  box-shadow: none;
  transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
}
.btn-send:hover {
  background: rgba(255,255,255,0.04);
  border-color: var(--border-hover);
  color: var(--accent-hover);
}
.btn-send:active { transform: none; }
.btn-send:disabled { background: var(--bg-4); color: var(--text-3); cursor: not-allowed; }
.btn-send svg {
  width: 12px;
  height: 12px;
}
body[data-theme="light"] .btn-send {
  background: transparent;
  border-color: var(--border);
  color: #089981;
}
body[data-theme="light"] .btn-send:hover {
  background: var(--bg-3);
  border-color: var(--border-hover);
  color: #089981;
}

.btn-stop {
  padding: 5px 12px;
  background: var(--red-dim);
  border: 1px solid rgba(239,68,68,0.3);
  border-radius: var(--radius-sm);
  color: var(--red);
  font-size: 12px;
  cursor: pointer;
  font-family: var(--font);
  transition: all 0.2s ease;
}
.btn-stop:hover { background: rgba(239,68,68,0.2); }

.btn-icon {
  width: 24px;
  height: 24px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: transparent;
  color: var(--text-2);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  cursor: pointer;
  transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
}
.btn-icon svg {
  display: block;
  width: 12px;
  height: 12px;
}
.btn-icon:hover {
  background: rgba(255,255,255,0.04);
  border-color: var(--border-hover);
  color: var(--text-1);
}
.btn-attach.has-items {
  border-color: rgba(59, 180, 168, 0.7);
  color: var(--accent-hover);
  background: rgba(59, 180, 168, 0.08);
}
.btn-icon.recording {
  background: var(--red-dim);
  border-color: rgba(239,68,68,0.4);
  color: var(--red);
}

#send-btn {
  align-self: center;
}

.composer-hint { display: flex; justify-content: space-between; align-items: center; gap: 10px; padding: 8px 2px 0; font-size: 11px; color: var(--text-3); flex-wrap: wrap; }
.composer-hint-right { display: inline-flex; align-items: center; gap: 8px; min-width: 0; flex-wrap: wrap; justify-content: flex-end; }
.direct-save-badge {
  display: inline-flex;
  align-items: center;
  height: 22px;
  padding: 0 9px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: rgba(255,255,255,0.03);
  color: var(--text-2);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  white-space: nowrap;
}
.direct-save-badge.state-ready {
  border-color: rgba(16,185,129,0.32);
  background: rgba(16,185,129,0.12);
  color: var(--green);
}
.direct-save-badge.state-warn {
  border-color: rgba(255,191,71,0.35);
  background: rgba(255,191,71,0.12);
  color: #f6c56f;
}
.direct-save-badge.state-off {
  border-color: var(--border);
  background: rgba(255,255,255,0.03);
  color: var(--text-2);
}
.direct-save-badge.state-blocked {
  border-color: rgba(239,68,68,0.3);
  background: rgba(239,68,68,0.12);
  color: #ff9b9b;
}
.composer-token {
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 1px 6px;
  color: var(--text-3);
  font-family: var(--mono);
  font-size: 10px;
  white-space: nowrap;
}
.composer-token.warning { color: #f59e0b; }
.composer-token.critical { color: var(--red); }
#stream-status { color: var(--accent-hover); }

.composer-attachments {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 8px;
}
.attachment-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 3px 8px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: var(--bg-2);
  color: var(--text-2);
  font-size: 11px;
  max-width: 260px;
}
.attachment-pill span {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.attachment-pill button {
  border: none;
  background: transparent;
  color: var(--text-3);
  cursor: pointer;
  font-size: 12px;
}
.attachment-pill button:hover { color: var(--red); }

.templates-dropdown {
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--bg-2);
  margin-bottom: 8px;
  max-height: 220px;
  overflow: hidden;
}
.templates-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 10px;
  border-bottom: 1px solid var(--border);
  font-size: 12px;
  color: var(--text-2);
}
.templates-list {
  max-height: 170px;
  overflow-y: auto;
  padding: 6px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.template-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  padding: 6px 8px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-2);
  font-size: 12px;
}
.template-item:hover {
  border-color: var(--border-hover);
  background: var(--bg-3);
}
.template-item button {
  border: none;
  background: transparent;
  color: var(--text-3);
  cursor: pointer;
  font-size: 11px;
}
.template-item button:hover { color: var(--red); }

.msg-attachments {
  margin-top: 6px;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.msg-attachment-pill {
  display: inline-flex;
  align-items: center;
  padding: 1px 7px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: var(--bg-2);
  color: var(--text-3);
  font-size: 10px;
}

.compare-row {
  display: flex;
  gap: 12px;
  padding: 6px 24px 2px;
}
.compare-col {
  flex: 1;
  min-width: 0;
  border: 1px solid var(--border);
  border-radius: 14px;
  overflow: hidden;
  background: rgba(255,255,255,0.02);
  box-shadow: 0 10px 24px rgba(0,0,0,0.08);
}
.compare-col .msg-wrapper {
  padding: 10px 12px;
}

.mcp-list,
.mcp-tools-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.mcp-item,
.mcp-tool-item {
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 7px 8px;
  background: var(--bg-2);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
  font-size: 11px;
  color: var(--text-2);
}
.mcp-tool-item label {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
}

/* â”€â”€ Right Panel â”€â”€ */
.right-panel {
  width: var(--panel-w);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.02), transparent 20%),
    var(--bg-1);
  border-left: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: inset 1px 0 0 rgba(255,255,255,0.02);
}

.panel-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 16px 18px 14px;
  border-bottom: 1px solid var(--border);
}
.panel-title {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-2);
}
.panel-close-btn {
  width: 28px;
  height: 28px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--text-2);
  cursor: pointer;
}
.panel-close-btn:hover {
  background: var(--bg-3);
  color: var(--text-1);
  border-color: var(--border-hover);
}
.panel-tabs { display: none; border-bottom: 1px solid var(--border); }
.panel-tab {
  flex: 1; padding: 11px 8px;
  background: transparent;
  border: none; border-bottom: 2px solid transparent;
  color: var(--text-3); font-size: 12px; font-weight: 500;
  cursor: pointer; font-family: var(--font);
  transition: all 0.15s;
}
.panel-tab:hover { color: var(--text-2); }
.panel-tab.active { color: var(--text-1); border-bottom-color: var(--accent); }

.panel-body { display: none; flex-direction: column; gap: 16px; padding: 18px; overflow-y: auto; flex: 1; }
.panel-body.active { display: flex; }
.panel-body::-webkit-scrollbar { width: 4px; }
.panel-body::-webkit-scrollbar-thumb { background: var(--bg-4); border-radius: 2px; }

.panel-section { display: flex; flex-direction: column; gap: 6px; }
.field-label { font-size: 11px; color: var(--text-3); font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; }
.field-help {
  margin-top: -2px;
  font-size: 11px;
  color: var(--text-3);
  line-height: 1.5;
}
.field-help code {
  background: var(--bg-3);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 1px 5px;
  font-family: var(--mono);
  font-size: 10.5px;
}
.field-row { display: flex; gap: 6px; }
.provider-mode-row { display: flex; gap: 6px; }
.provider-mode-btn { flex: 1; text-align: center; }
.provider-mode-btn.active {
  color: var(--text-1);
  border-color: rgba(111, 231, 214, 0.65);
  background: rgba(111, 231, 214, 0.14);
}

.field-input {
  width: 100%;
  background: rgba(255,255,255,0.025);
  border: 1px solid var(--border);
  border-radius: 10px;
  color: var(--text-1);
  font-size: 13px;
  padding: 7px 10px;
  font-family: var(--font);
  outline: none;
  transition: border-color 0.15s;
}
.field-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,245,196,0.1); }
textarea.field-input { resize: vertical; font-family: var(--mono); font-size: 12px; }

.btn-row { display: flex; gap: 6px; flex-wrap: wrap; }

.btn-primary {
  padding: 7px 14px;
  background: var(--accent);
  border: none; border-radius: var(--radius-sm);
  color: #fff; font-size: 12px; font-weight: 500;
  cursor: pointer; font-family: var(--font);
  transition: background 0.15s;
}
.btn-primary:hover { background: var(--accent-hover); }

.btn-ghost {
  padding: 7px 14px;
  background: transparent;
  border: 1px solid var(--border); border-radius: var(--radius-sm);
  color: var(--text-2); font-size: 12px;
  cursor: pointer; font-family: var(--font);
  transition: all 0.2s ease;
}
.btn-ghost:hover { background: var(--bg-3); color: var(--text-1); }

.btn-ghost-sm {
  padding: 4px 10px;
  background: transparent;
  border: 1px solid var(--border); border-radius: var(--radius-sm);
  color: var(--text-2); font-size: 11px;
  cursor: pointer; font-family: var(--font);
  transition: all 0.2s ease; white-space: nowrap;
}
.btn-ghost-sm:hover { background: var(--bg-3); color: var(--text-1); }
.btn-new:active, .btn-sidebar-action:active, .btn-ghost:active, .btn-ghost-sm:active, .btn-theme:active, .mode-btn:active { transform: scale(0.97); }

.status-msg { font-size: 12px; color: var(--text-3); min-height: 18px; }
.status-msg.ok { color: var(--green); }
.status-msg.err { color: var(--red); }

/* â”€â”€ Router Panel â”€â”€ */
.router-status-card {
  display: flex; align-items: center; gap: 10px;
  padding: 14px 15px;
  background: rgba(255,255,255,0.025);
  border: 1px solid var(--border);
  border-radius: 14px;
}
.router-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--text-3);
  flex-shrink: 0;
  transition: background 0.3s;
}
.router-dot.on { background: var(--green); box-shadow: 0 0 6px rgba(16,185,129,0.5); }
.router-dot.off { background: var(--text-3); }

#router-status-text { font-size: 13px; font-weight: 500; color: var(--text-1); display: block; }
#router-port-text { font-size: 11px; color: var(--text-3); display: block; }

.router-log {
  background: rgba(8, 12, 18, 0.72);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 10px 12px;
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text-2);
  height: 200px;
  overflow-y: auto;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
}
.router-log::-webkit-scrollbar { width: 4px; }
.router-log::-webkit-scrollbar-thumb { background: var(--bg-4); border-radius: 2px; }

/* â”€â”€ Modal â”€â”€ */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.6);
  display: flex; align-items: center; justify-content: center;
  z-index: 100;
  backdrop-filter: blur(4px);
}
.modal {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  width: 320px;
  display: flex; flex-direction: column; gap: 12px;
}
.modal-title { font-size: 14px; font-weight: 600; color: var(--text-1); }
.code-preview-modal {
  width: min(90vw, 900px);
  height: min(80vh, 700px);
  max-width: 900px;
  padding: 14px;
}
.code-preview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.code-preview-frame {
  width: 100%;
  height: 100%;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: #fff;
}
.stats-modal {
  width: min(90vw, 640px);
  max-width: 640px;
}
.stats-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 10px;
}
.stats-card {
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--bg-3);
  padding: 10px;
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.stats-label {
  font-size: 10px;
  color: var(--text-3);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.stats-value {
  font-size: 16px;
  color: var(--text-1);
}
.stats-subvalue {
  font-size: 11px;
  color: var(--text-3);
}
.messages { position: relative; }
.scroll-bottom-btn {
  position: absolute;
  right: 20px;
  bottom: 16px;
  z-index: 10;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: 32px;
  padding: 0 12px;
  border-radius: 16px;
  border: 1px solid rgba(0, 245, 196, 0.35);
  background: rgba(10, 14, 23, 0.92);
  color: #b9fff1;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.25);
}
.scroll-bottom-btn:hover {
  border-color: rgba(0, 245, 196, 0.55);
  color: #e8fffa;
}
body[data-theme="light"] .scroll-bottom-btn {
  background: rgba(255, 255, 255, 0.95);
  border-color: rgba(15, 23, 42, 0.22);
  color: var(--text-1);
}
.chat-summary-overlay {
  position: absolute;
  top: 12px;
  left: 24px;
  right: 24px;
  z-index: 9;
  display: flex;
  justify-content: center;
  pointer-events: none;
}
.chat-summary-card {
  width: min(100%, 760px);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--bg-2);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.25);
  pointer-events: auto;
  padding: 10px 12px;
}
.chat-summary-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6px;
}
.chat-summary-title {
  font-size: 11px;
  color: var(--text-3);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.chat-summary-content {
  font-size: 13px;
  color: var(--text-1);
  white-space: pre-wrap;
  max-height: 180px;
  overflow-y: auto;
}

/* â”€â”€ Toast â”€â”€ */
.toast {
  position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
  background: rgba(255, 255, 255, 0.96); border: 1px solid rgba(15, 23, 42, 0.14);
  border-radius: 14px; padding: 10px 18px;
  font-size: 13px; color: #0f172a;
  opacity: 0; pointer-events: none;
  transition: opacity 0.2s;
  z-index: 200;
  white-space: nowrap;
  backdrop-filter: blur(10px);
  box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
}
.toast.show { opacity: 1; }

@media (max-width: 1280px) {
  :root {
    --sidebar-w: 248px;
    --panel-w: 320px;
  }
  .chat-title-display {
    max-width: 220px;
  }
}

