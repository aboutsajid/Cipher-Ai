
{
  "name": "cipher-ai",
  "version": "1.1.0",
  "description": "Cipher Workspace - Desktop AI workspace with Claude Code Router",
  "main": "dist/main/main.js",
  "author": "Cipher",
  "license": "MIT",
  "scripts": {
    "clean": "node scripts/clean-paths.mjs dist",
    "clean:release": "node scripts/clean-paths.mjs release",
    "build:ts": "tsc -p tsconfig.json",
    "build:assets": "node scripts/copy-assets.mjs",
    "build": "npm run clean && npm run build:ts && npm run build:assets",
    "test": "npm run build && node scripts/run-tests.mjs",
    "smoke:electron:start": "npm run build && node scripts/electron-startup-smoke.mjs",
    "start": "npm run build && node scripts/launch-electron.mjs",
    "dev": "npm run build && node scripts/launch-electron.mjs",
    "pack:win": "npm run build && npm run clean:release && electron-builder --win nsis --publish never",
    "soak:agent:prompts": "node scripts/agent-soak-report.mjs prompts",
    "soak:agent:report": "node scripts/agent-soak-report.mjs report",
    "soak:agent:run": "node scripts/agent-soak-run.mjs",
    "soak:agent:manual:prompts": "node scripts/agent-soak-report.mjs prompts --scenarios-file prompts/agent-manual-freeform-pack.json --markdown tmp/agent-manual-freeform-prompts.md",
    "soak:agent:manual:report": "node scripts/agent-soak-report.mjs report --scenarios-file prompts/agent-manual-freeform-pack.json --markdown tmp/agent-manual-freeform-report.md --json tmp/agent-manual-freeform-report.json --history tmp/agent-manual-freeform-history.json",
    "soak:agent:manual:run": "node scripts/agent-soak-run.mjs --scenarios-file prompts/agent-manual-freeform-pack.json --markdown tmp/agent-manual-freeform-report.md --json tmp/agent-manual-freeform-report.json",
    "soak:agent:critical:prompts": "node scripts/agent-soak-report.mjs prompts --scenarios-file prompts/agent-critical-pack.json --markdown tmp/agent-critical-prompts.md",
    "soak:agent:critical:report": "node scripts/agent-soak-report.mjs report --scenarios-file prompts/agent-critical-pack.json --markdown tmp/agent-critical-report.md --json tmp/agent-critical-report.json --history tmp/agent-critical-history.json",
    "soak:agent:critical:run": "node scripts/agent-soak-run.mjs --scenarios-file prompts/agent-critical-pack.json --markdown tmp/agent-critical-report.md --json tmp/agent-critical-report.json",
    "soak:agent:realworld:prompts": "node scripts/agent-soak-report.mjs prompts --scenarios-file prompts/agent-realworld-pack.json --markdown tmp/agent-realworld-prompts.md",
    "soak:agent:realworld:report": "node scripts/agent-soak-report.mjs report --scenarios-file prompts/agent-realworld-pack.json --markdown tmp/agent-realworld-report.md --json tmp/agent-realworld-report.json --history tmp/agent-realworld-history.json",
    "soak:agent:realworld:run": "node scripts/agent-soak-run.mjs --scenarios-file prompts/agent-realworld-pack.json --markdown tmp/agent-realworld-report.md --json tmp/agent-realworld-report.json",
    "agent:real-usage:init": "node scripts/init-real-usage-log.mjs",
    "smoke:win:install": "node scripts/smoke-win-installer.mjs",
    "smoke:win:update": "node scripts/smoke-win-installer.mjs",
    "smoke:win:summary": "node scripts/format-win-smoke-report.mjs",
    "start:backend": "node src/server.js"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "marked": "^9.0.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.cipher.ai",
    "productName": "Cipher Workspace",
    "executableName": "Cipher Workspace",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "src/renderer/assets/cipher-ai-icon.ico",
        "to": "assets/cipher-ai-icon.ico"
      }
    ],
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/renderer/assets/cipher-ai-icon.ico"
    },
    "nsis": {
      "artifactName": "Cipher-Workspace-Setup-${version}.exe",
      "oneClick": false,
      "createDesktopShortcut": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "src/renderer/assets/cipher-ai-icon.ico",
      "uninstallerIcon": "src/renderer/assets/cipher-ai-icon.ico",
      "installerHeaderIcon": "src/renderer/assets/cipher-ai-icon.ico"
    }
  }
}
